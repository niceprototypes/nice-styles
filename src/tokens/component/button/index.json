{
  "size": {
    "smaller": "var(--np--cell-height--smaller)",
    "small": "var(--np--cell-height--small)",
    "base": "var(--np--cell-height--base)",
    "large": "var(--np--cell-height--large)",
    "larger": "var(--np--cell-height--larger)"
  },
  "spacing": {
    "smaller": "calc(var(--np--cell-height--smaller) / 2)",
    "small": "calc(var(--np--cell-height--small) / 2)",
    "base": "calc(var(--np--cell-height--base) / 2)",
    "large": "calc(var(--np--cell-height--large) / 2)",
    "larger": "calc(var(--np--cell-height--larger) / 2)"
  },
  "borderRadius": {
    "smaller": "var(--np--border-radius--smaller)",
    "small": "var(--np--border-radius--small)",
    "base": "var(--np--border-radius--base)",
    "large": "var(--np--border-radius--large)",
    "larger": "var(--np--border-radius--larger)"
  },
  "statusPrimaryBase": {
    "backgroundColor": "var(--np--foreground-color--base)",
    "borderColor": "var(--np--foreground-color--base)",
    "foregroundColor": "#fff"
  },
  "statusPrimaryDisabled": {
    "backgroundColor": "#ddd",
    "borderColor": "#ddd",
    "foregroundColor": "#888"
  },
  "statusPrimaryError": {
    "backgroundColor": "var(--np--foreground-color--error)",
    "borderColor": "var(--np--foreground-color--error)",
    "foregroundColor": "#fff"
  },
  "statusPrimarySuccess": {
    "backgroundColor": "var(--np--foreground-color--success)",
    "borderColor": "var(--np--foreground-color--success)",
    "foregroundColor": "#fff"
  },
  "statusPrimaryWarning": {
    "backgroundColor": "var(--np--foreground-color--warning)",
    "borderColor": "var(--np--foreground-color--warning)",
    "foregroundColor": "#fff"
  },
  "statusSecondaryBase": {
    "backgroundColor": "transparent",
    "borderColor": "var(--np--foreground-color--base)",
    "foregroundColor": "var(--np--foreground-color--base)"
  },
  "statusSecondaryDisabled": {
    "backgroundColor": "transparent",
    "borderColor": "#ddd",
    "foregroundColor": "#888"
  },
  "statusSecondaryError": {
    "backgroundColor": "transparent",
    "borderColor": "var(--np--foreground-color--error)",
    "foregroundColor": "var(--np--foreground-color--error)"
  },
  "statusSecondarySuccess": {
    "backgroundColor": "transparent",
    "borderColor": "var(--np--foreground-color--success)",
    "foregroundColor": "var(--np--foreground-color--success)"
  },
  "statusSecondaryWarning": {
    "backgroundColor": "transparent",
    "borderColor": "var(--np--foreground-color--warning)",
    "foregroundColor": "var(--np--foreground-color--warning)"
  }
}