{
  "animationDuration": {
    "base": "300ms",
    "slow": "600ms"
  },
  "backgroundSize": {
    "contain": "contain",
    "cover": "cover",
    "fill": "fill",
    "none": "none",
    "scale-down": "scale-down"
  },
  "animationEasing": {
    "base": "ease-in-out"
  },
  "borderRadius": {
    "smaller": "2px",
    "small": "4px",
    "base": "8px",
    "large": "16px",
    "larger": "32px"
  },
  "borderWidth": {
    "none": "0",
    "small": "1px",
    "base": "1.5px",
    "large": "2px"
  },
  "boxShadow": {
    "base": "0 1px 4px hsla(0, 0%, 0%, 0.075)",
    "large": "0 2px 8px hsla(0, 0%, 0%, 0.1)"
  },
  "cellHeight": {
    "smaller": "24px",
    "small": "32px",
    "base": "48px",
    "large": "64px",
    "larger": "72px"
  },
  "fontFamily": {
    "base": "\"Google Sans Flex\", sans-serif",
    "code": "\"Roboto Mono\", \"Courier New\", monospace",
    "heading": "\"Google Sans Flex\", sans-serif"
  },
  "fontWeight": {
    "light": "300",
    "base": "400",
    "medium": "500",
    "semibold": "600",
    "bold": "700",
    "extrabold": "800",
    "black": "900"
  },
  "gap": {
    "none": "0",
    "smaller": "4px",
    "small": "8px",
    "base": "16px",
    "large": "32px",
    "larger": "48px"
  },
  "letterSpacing": {
    "tight": "-0.025em",
    "base": "0",
    "wide": "0.025em",
    "wider": "0.05em"
  },
  "lineHeight": {
    "single": "1",
    "condensed": "1.25",
    "base": "1.5",
    "expanded": "1.75"
  },
  "color": {
    "base": "hsla(210, 5%, 5%, 1)",
    "light": "hsla(210, 5%, 25%, 1)",
    "lighter": "hsla(210, 5%, 50%, 1)",
    "lightest": "hsla(210, 5%, 75%, 1)",
    "disabled": "hsla(210, 5%, 5%, 0.6)",
    "link": "hsla(212, 100%, 46%, 1)",
    "success": "hsla(146, 68%, 44%, 1)",
    "warning": "hsla(29, 98%, 62%, 1)",
    "error": "hsla(10, 92%, 63%, 1)"
  },
  "backgroundColor": {
    "base": "hsla(0, 5%, 100%, 1)",
    "dark": "hsla(0, 5%, 95%, 1)"
  },
  "borderColor": {
    "base": "hsla(240, 9%, 91%, 1)",
    "dark": "hsla(210, 8%, 58%, 1)",
    "darker": "hsla(210, 10%, 20%, 1)"
  },
  "$breakpoints": {
    "phone": {
      "fontSize": {
        "smaller": "11px",
        "small": "12px",
        "base": "14px",
        "large": "20px",
        "larger": "28px"
      }
    },
    "tablet": {
      "fontSize": {
        "smaller": "11px",
        "small": "12px",
        "base": "14px",
        "large": "20px",
        "larger": "28px"
      }
    },
    "laptop": {
      "fontSize": {
        "smaller": "12px",
        "small": "14px",
        "base": "16px",
        "large": "24px",
        "larger": "32px"
      }
    },
    "desktop": {
      "fontSize": {
        "smaller": "12px",
        "small": "14px",
        "base": "16px",
        "large": "24px",
        "larger": "32px"
      }
    }
  },
  "$themes": {
    "night": {
      "color": {
        "base": "hsla(210, 5%, 95%, 1)",
        "light": "hsla(210, 5%, 95%, 0.85)",
        "lighter": "hsla(210, 5%, 95%, 0.55)",
        "lightest": "hsla(210, 5%, 95%, 0.25)",
        "disabled": "hsla(210, 5%, 95%, 0.6)",
        "link": "hsla(202, 90%, 65%, 1)",
        "success": "hsla(146, 58%, 59%, 1)",
        "warning": "hsla(29, 88%, 72%, 1)",
        "error": "hsla(10, 82%, 75%, 1)"
      },
      "backgroundColor": {
        "base": "hsla(240, 5%, 15%, 1)",
        "dark": "hsla(240, 5%, 12.5%, 1)"
      },
      "borderColor": {
        "base": "hsla(240, 5%, 25%, 1)",
        "dark": "hsla(240, 5%, 50%, 1)",
        "darker": "hsla(240, 5%, 100%, 1)"
      }
    }
  }
}
