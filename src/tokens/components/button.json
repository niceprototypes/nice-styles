{
  "size": {
    "smaller": "var(--np--cell-height--smaller)",
    "small": "var(--np--cell-height--small)",
    "base": "var(--np--cell-height--base)",
    "large": "var(--np--cell-height--large)",
    "larger": "var(--np--cell-height--larger)"
  },
  "spacing": {
    "smaller": "calc(var(--np--cell-height--smaller) / 2)",
    "small": "calc(var(--np--cell-height--small) / 2)",
    "base": "calc(var(--np--cell-height--base) / 2)",
    "large": "calc(var(--np--cell-height--large) / 2)",
    "larger": "calc(var(--np--cell-height--larger) / 2)"
  },
  "borderRadius": {
    "smaller": "var(--np--border-radius--smaller)",
    "small": "var(--np--border-radius--small)",
    "base": "var(--np--border-radius--base)",
    "large": "var(--np--border-radius--large)",
    "larger": "var(--np--border-radius--larger)"
  },
  "status": {
    "primary": {
      "backgroundColor": {
        "base": "var(--np--color--base)",
        "disabled": "#ddd",
        "error": "var(--np--color--error)",
        "success": "var(--np--color--success)",
        "warning": "var(--np--color--warning)"
      },
      "borderColor": {
        "base": "var(--np--color--base)",
        "disabled": "#ddd",
        "error": "var(--np--color--error)",
        "success": "var(--np--color--success)",
        "warning": "var(--np--color--warning)"
      },
      "color": {
        "base": "var(--np--color--base--night)",
        "disabled": "#888",
        "error": "#fff",
        "success": "#fff",
        "warning": "#fff"
      }
    },
    "secondary": {
      "backgroundColor": {
        "base": "transparent",
        "disabled": "transparent",
        "error": "transparent",
        "success": "transparent",
        "warning": "transparent"
      },
      "borderColor": {
        "base": "var(--np--color--lightest)",
        "disabled": "#ddd",
        "error": "var(--np--color--error)",
        "success": "var(--np--color--success)",
        "warning": "var(--np--color--warning)"
      },
      "color": {
        "base": "var(--np--color--base)",
        "disabled": "#888",
        "error": "var(--np--color--error)",
        "success": "var(--np--color--success)",
        "warning": "var(--np--color--warning)"
      }
    }
  },
  "$themes": {
    "night": {
      "status": {
        "primary": {
          "backgroundColor": {
            "base": "var(--np--color--base--night)",
            "disabled": "var(--np--color--base--night)",
            "error": "var(--np--color--error--night)",
            "success": "var(--np--color--success--night)",
            "warning": "var(--np--color--warning--night)"
          },
          "borderColor": {
            "base": "var(--np--color--base--night)",
            "disabled": "var(--np--color--base--night)",
            "error": "var(--np--color--error--night)",
            "success": "var(--np--color--success--night)",
            "warning": "var(--np--color--warning--night)"
          },
          "color": {
            "base": "var(--np--color--base--day)",
            "disabled": "var(--np--color--base--day)",
            "error": "var(--np--color--base--day)",
            "success": "var(--np--color--base--day)",
            "warning": "var(--np--color--base--day)"
          }
        },
        "secondary": {
          "backgroundColor": {
            "base": "transparent",
            "disabled": "transparent",
            "error": "transparent",
            "success": "transparent",
            "warning": "transparent"
          },
          "borderColor": {
            "base": "var(--np--color--lightest--night)",
            "disabled": "var(--np--color--base--night)",
            "error": "var(--np--color--error--night)",
            "success": "var(--np--color--success--night)",
            "warning": "var(--np--color--warning--night)"
          },
          "color": {
            "base": "var(--np--color--base--night)",
            "disabled": "var(--np--color--base--night)",
            "error": "var(--np--color--error--night)",
            "success": "var(--np--color--success--night)",
            "warning": "var(--np--color--warning--night)"
          }
        }
      }
    }
  }
}
